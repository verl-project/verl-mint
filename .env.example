# Copy this file to .env for local or cluster runs.

# Artifact root used by verl-mint for checkpoints and sampler weights.
VERL_MINT_STORAGE_ROOT=/shared/path/verl-mint

# One or more filesystem roots that are visible from every node.
# Use ":" to separate multiple roots on Linux/macOS.
VERL_MINT_SHARED_STORAGE_ROOTS=/shared/path

# Set to 1 only when you intentionally trust VERL_MINT_STORAGE_ROOT as shared.
# VERL_MINT_STORAGE_SHARED=1
